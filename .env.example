# =========================================================
# APP
# =========================================================
NODE_ENV=development
PORT=3000

APP_NAME=onlyflans-api
API_PREFIX=/api

# Ejemplo local:
# http://localhost:3000
BACKEND_URL=http://localhost:3000

# Ejemplo frontend local:
# http://localhost:5173
FRONTEND_URL=http://localhost:5173


# =========================================================
# DATABASE - POSTGRESQL / NEON
# =========================================================
# Opción recomendada si usas Neon o una URL completa:
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require

# Si tu db.config usa variables separadas, puedes usar estas:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=onlyflans
DB_USER=postgres
DB_PASSWORD=postgres

# SSL para Neon / producción
DB_SSL=true

# Pool Sequelize
DB_POOL_MAX=10
DB_POOL_MIN=0
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000


# =========================================================
# JWT / AUTH
# =========================================================
JWT_ACCESS_SECRET=change_this_access_secret
JWT_REFRESH_SECRET=change_this_refresh_secret

JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

COOKIE_NAME=access_token
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_MAX_AGE_MS=900000


# =========================================================
# CORS
# =========================================================
# Separar múltiples orígenes con coma
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

CORS_CREDENTIALS=true


# =========================================================
# LOGGING
# =========================================================
LOG_LEVEL=info
LOG_PRETTY=true


# =========================================================
# RATE LIMIT
# =========================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100


# =========================================================
# COMPRESSION
# =========================================================
COMPRESSION_ENABLED=true
COMPRESSION_LEVEL=6
COMPRESSION_THRESHOLD=1024


# =========================================================
# UPLOADS / IMÁGENES
# =========================================================
# Si por ahora solo guardas URLs de imágenes, puedes dejar esto como referencia.
MAX_IMAGES_PER_PUBLICACION=10

# Si luego manejas subida local:
UPLOAD_DIR=uploads
PUBLIC_UPLOAD_URL=http://localhost:3000/uploads

# Si luego usas Cloudinary, S3 u otro servicio:
IMAGE_PROVIDER=external
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=


# =========================================================
# REDIS - OPCIONAL
# =========================================================
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379


# =========================================================
# SEGURIDAD
# =========================================================
HELMET_ENABLED=true
TRUST_PROXY=false